# ─── Dokan360 Port Configuration ─────────────────────────────────────────────
# এই file-এ সব port define করা আছে।
# Port পরিবর্তন করতে হলে শুধু এখানে করুন।
#
# Internal → External mapping:
#   API_PORT  8080  →  :8080  (Express API, "Backend" workflow)
#   PORT      5000  →  :80    (frontend, "artifacts/dokan360: web" workflow / webview)

# API server listens on this port
API_PORT=8080

# Frontend (Vite) listens on this port — managed by artifacts/dokan360: web
PORT=5000
